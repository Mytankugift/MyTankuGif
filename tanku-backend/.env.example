# ePayco — variables adicionales para Smart Checkout y firma de webhook
# Copiar las que falten a tu archivo .env local.

# Por defecto en código: smart. Solo si necesitas el checkout antiguo (checkout.js):
# EPAYCO_CHECKOUT_MODE=classic

# Firma del webhook (recomendado en producción; ver dashboard ePayco)
# EPAYCO_CUSTOMER_ID=
# EPAYCO_P_KEY=

# Email (Gmail SMTP con App Password; POST /api/v1/email/test)
# EMAIL_USER=tu_cuenta@gmail.com
# EMAIL_PASS=16caracteressinespacios (sin guiones; el de Google son 16 chars)
# EMAIL_PROVIDER=gmail
# Opcional en PaaS sin IPv6: NODE_OPTIONS=--dns-result-order=ipv4first
# El código fuerza IPv4 (family:4) en smtp.gmail.com:587.

