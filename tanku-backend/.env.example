# ePayco — variables adicionales para Smart Checkout y firma de webhook
# Copiar las que falten a tu archivo .env local.

# Por defecto en código: smart. Solo si necesitas el checkout antiguo (checkout.js):
# EPAYCO_CHECKOUT_MODE=classic

# Firma del webhook (recomendado en producción; ver dashboard ePayco)
# EPAYCO_CUSTOMER_ID=
# EPAYCO_P_KEY=

# Email (Gmail SMTP con App Password; POST /api/v1/email/test)
# EMAIL_USER=tu_cuenta@gmail.com
# EMAIL_PASS=16caracteressinespacios (sin guiones; el de Google son 16 chars)
# EMAIL_PROVIDER=gmail
# Opcional en PaaS sin IPv6: NODE_OPTIONS=--dns-result-order=ipv4first
# El código fuerza IPv4 (family:4) en smtp.gmail.com:587.

# CORS: origins separados por coma. En local, si usás tanku-admin (puerto 3001), debe incluir:
# CORS_ORIGINS=http://localhost:8000,http://localhost:3001

# Cron Dropi sync-stock (default si no hay config en BD; admin puede cambiarla)
# Cada 10 min: */10 * * * *  |  Cada 15 min: */15 * * * *
ENABLE_CRON_JOBS=true
DROPI_SYNC_CRON=*/10 * * * *
# Zona IANA para el cron (opcional; default America/Bogota en código)
# DROPI_SYNC_CRON_TZ=America/Bogota

# Postventa: URL del ERP (enlaces en correos a soporte). Si no se define, se infiere de CORS (:3001).
# ADMIN_FRONTEND_URL=https://erp-tanku-admin.vercel.app

# Postventa: días antes de borrar evidencias en S3 (default 90)
# SUPPORT_EVIDENCE_RETENTION_DAYS=90
# SUPPORT_EVIDENCE_RETENTION_CRON_TZ=America/Bogota
